# Copy this file to .env for local use, or export the variable in your shell.
# Never commit a real API key.
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Unified MIMIC-CXR-JPG location. Keep this relative by default.
# Put the dataset here or create a symlink:
#   data/mimic-cxr-jpg -> ../external_datasets/MIMIC-CXR-JPG
MIMIC_CXR_JPG_ROOT=data/mimic-cxr-jpg
